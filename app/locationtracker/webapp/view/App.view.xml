<mvc:View
  controllerName="com.locationtracker.locationtracker.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">
  <App id="app">
    <pages>
      <Page title="Live Location Tracker">
        <content>
          <VBox class="trackerPage">
            <VBox class="heroSection">
              <HBox class="heroRow" wrap="Wrap" justifyContent="SpaceBetween" alignItems="Center">
                <VBox class="heroText">
                  <Title text="Track every trip in real time" level="H2" />
                  <Text text="Monitor live coordinates, route quality, and operational KPIs from one dashboard." class="heroSubtitle" />
                </VBox>
                <HBox wrap="Wrap" class="buttonCluster">
                  <Button text="Start Trip" type="Emphasized" press=".onStartTracking" visible="{= !${view>/tracking} }" />
                  <Button text="Stop Trip" type="Reject" press=".onStopTracking" visible="{view>/tracking}" />
                  <Button text="Refresh Path" icon="sap-icon://refresh" press=".onRefreshPath" />
                </HBox>
              </HBox>
              <HBox class="statusStrip" wrap="Wrap" alignItems="Center">
                <ObjectStatus title="System Status" text="{view>/statusText}" state="{= ${view>/tracking} ? 'Success' : 'Information' }" />
                <ObjectStatus title="Location Permission" text="{view>/permissionText}" state="{= ${view>/tracking} ? 'Success' : 'Warning' }" />
              </HBox>
            </VBox>

            <HBox wrap="Wrap" class="cardRow kpiRow">
              <Panel headerText="Current Trip" class="metricCard kpiCard">
                <content>
                  <VBox class="metricContent">
                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                      <ObjectStatus title="Title" text="{= ${view>/currentTrip/title} || 'No active trip'}" />
                      <core:Icon src="sap-icon://journey-change" class="kpiIcon" />
                    </HBox>
                    <ObjectStatus title="Status" text="{= ${view>/currentTrip/status} || 'IDLE'}" state="{= ${view>/currentTrip/status} === 'ACTIVE' ? 'Success' : 'Information' }" />
                    <ObjectStatus title="Started At" text="{= ${view>/currentTrip/startedAt} || '-'}" />
                  </VBox>
                </content>
              </Panel>

              <Panel headerText="Live Position" class="metricCard kpiCard">
                <content>
                  <VBox class="metricContent">
                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                      <Title text="Latest Coordinates" level="H5" />
                      <core:Icon src="sap-icon://map-3" class="kpiIcon" />
                    </HBox>
                    <ObjectStatus title="Latitude" text="{= ${view>/lastPoint/latitude} || '-'}" />
                    <ObjectStatus title="Longitude" text="{= ${view>/lastPoint/longitude} || '-'}" />
                    <ObjectStatus title="Accuracy (m)" text="{= ${view>/lastPoint/accuracy} || '-'}" />
                  </VBox>
                </content>
              </Panel>

              <Panel headerText="Captured Points" class="metricCard kpiCard">
                <content>
                  <VBox class="metricContent">
                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                      <Title text="Path Density" level="H5" />
                      <core:Icon src="sap-icon://line-chart" class="kpiIcon" />
                    </HBox>
                    <ObjectNumber number="{view>/totalPoints}" unit="pts" />
                    <ProgressIndicator percentValue="{= ${view>/totalPoints} > 500 ? 100 : ${view>/totalPoints} / 5 }" displayValue="{= ${view>/totalPoints} + ' points captured'}" state="Success" />
                  </VBox>
                </content>
              </Panel>
            </HBox>

            <Panel headerText="Route Map" class="mapPanel">
              <content>
                <VBox class="mapShell">
                  <core:HTML content='&lt;div id="tracker-map" class="trackerMap"&gt;&lt;/div&gt;' />
                </VBox>
              </content>
            </Panel>

            <Panel headerText="Performance Metrics" class="metricCard metricsPanel">
              <content>
                <HBox wrap="Wrap" class="cardRow">
                  <VBox class="metricContent metricColumn">
                    <ObjectStatus title="Total Trips" text="{view>/metrics/totalTrips}" />
                    <ObjectStatus title="Completed Trips" text="{view>/metrics/completedTrips}" />
                    <ObjectStatus title="Completion Rate" text="{= ${view>/metrics/completionRate} + '%'}" state="Success" />
                    <ObjectStatus title="Avg Points / Trip" text="{view>/metrics/avgPointsPerTrip}" />
                    <ObjectStatus title="Avg GPS Accuracy (m)" text="{view>/metrics/avgGpsAccuracy}" />
                  </VBox>
                  <VBox class="metricContent metricColumn">
                    <ObjectStatus title="Avg Session Duration (ms)" text="{view>/metrics/avgSessionDurationMs}" />
                    <ObjectStatus title="Backend Ingest Success" text="{= ${view>/metrics/ingestSuccessRate} + '%'}" state="Success" />
                    <ObjectStatus title="Avg Backend Ingest Latency (ms)" text="{view>/metrics/avgIngestLatencyMs}" />
                    <ObjectStatus title="Avg Client Update Latency (ms)" text="{view>/metrics/avgClientUpdateLatencyMs}" />
                    <ObjectStatus title="Latest Client Update Latency (ms)" text="{view>/metrics/latestClientUpdateLatencyMs}" />
                  </VBox>
                </HBox>
              </content>
            </Panel>
          </VBox>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
